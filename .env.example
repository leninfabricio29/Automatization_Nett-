# MongoDB Configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=rpa_automatization

# Database Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Application Settings
APP_ENV=development
APP_DEBUG=True
LOG_LEVEL=INFO

# Playwright Settings
PLAYWRIGHT_HEADLESS=True
PLAYWRIGHT_TIMEOUT=30000

# Login Settings
LOGIN_URL=https://erp.nettplus.net/
LOGIN_USERNAME=your_username_here
LOGIN_PASSWORD=your_password_here

# Session Settings
SESSION_STORAGE_PATH=./sesion
